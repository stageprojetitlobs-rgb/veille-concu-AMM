# ============================================================
# Copier en .env et remplir les valeurs.
# JAMAIS committer .env dans git (cf .gitignore).
# ============================================================

# ── Slack ────────────────────────────────────────────────────
# Webhook entrant pour les notifications live.
# Sans valeur → le notifier reste en mode console (logs uniquement, --dry-run inutile).
# Obtenir : api.slack.com/apps → Create App → Incoming Webhooks
#           → Add New Webhook to Workspace → choisir #veille-concurrents
# Format attendu : https://hooks.slack.com/services/<TEAM>/<CHANNEL>/<TOKEN>
SLACK_WEBHOOK_URL=

# ── Identité HTTP ────────────────────────────────────────────
# User-Agent transparent envoyé à toutes les sources.
# Mettre un email de contact réel (bonne pratique).
VEILLE_USER_AGENT=veille-lobs/0.1 (+contact@lobs.fr)

# ── Dashboard en ligne (mot de passe) ────────────────────────
# Uniquement pour un déploiement cloud accessible depuis Internet.
# Si DASH_PASSWORD est défini, le dashboard exige ce mot de passe (Basic Auth).
# Laisser vide en local = aucun mot de passe demandé.
DASH_USER=lobs
DASH_PASSWORD=

# ── Kepro.nl ─────────────────────────────────────────────────
# Portail B2B professionnel — débloque pages produits complets (molécules, PDFs).
# Inscription : https://www.kepro.nl/register (validation manuelle 1-3 jours)
# Procédure détaillée : docs/acces_kepro_nl.md
KEPRO_USERNAME=votre.email@lobs.fr
KEPRO_PASSWORD=

# ── France Travail (API officielle offres d'emploi) ──────────
# API gratuite pour partenaires développeurs.
# Inscription : https://francetravail.io/data/api/offres-emploi
#   → Créer une application → Ajouter l'API "Offres d'emploi v2"
#   → Copier Client ID + Client Secret
# Scope requis : api_offresdemploiv2 o2dsoffre
FRANCE_TRAVAIL_CLIENT_ID=
FRANCE_TRAVAIL_CLIENT_SECRET=

# ── EMA UPD (OAuth2) ─────────────────────────────────────────
# API officielle EMA — AMM vétérinaires UE complètes.
# Démarche ~2-4 semaines via les Affaires Réglementaires.
# Procédure complète : docs/ema_upd_cadrage.md
# Après réception : passer sources.ema_upd.enabled: true + mode: live dans config.yaml
EMA_UPD_CLIENT_ID=
EMA_UPD_CLIENT_SECRET=
EMA_UPD_TOKEN_URL=https://spor.ema.europa.eu/oauth/token
